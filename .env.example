# Database
DATABASE_URL=postgresql://postgres:codepop123@localhost:5432/codepop

# PostgreSQL root password (used by docker-compose)
POSTGRES_PASSWORD=codepop123

# GitHub Webhook Secret (optional, for verifying push signatures)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Embedding model (HuggingFace model name or local path)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Code storage directory
REPOS_DIR=./repos

# API configuration
API_HOST=0.0.0.0
API_PORT=8080

# Logging
LOG_LEVEL=INFO
